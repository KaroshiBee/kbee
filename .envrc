# direnv config for the kbee repo.
# Activate with `direnv allow` after editing.

use flake

# Installing AnadigmDesigner2 under Wine made xdg-mime claim .html for
# wine-extension-htm.desktop, so `xdg-open foo.html` launches a Wine
# HTML stub instead of a real browser (with a noisy KDE portal error).
# Pin the browser explicitly for CAM HTML.
export BROWSER=firefox
